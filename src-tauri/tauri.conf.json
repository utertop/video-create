{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Video Create Studio",
  "version": "5.6.0",
  "identifier": "com.video-create.studio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Video Create Studio",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost; video-src 'self' asset: https://asset.localhost; media-src 'self' asset: https://asset.localhost;",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [],
    "resources": {
      "../video_engine_v5.py": "video_engine_v5.py",
      "../video_engine_worker.py": "video_engine_worker.py"
    }
  }
}
