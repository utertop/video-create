{
  "name": "video-create-studio",
  "private": true,
  "version": "5.6.0",
  "type": "module",
  "scripts": {
    "build:web": "tsc && vite build",
    "dev": "vite --host 127.0.0.1 --port 1420",
    "build": "npm run build:web",
    "build:worker": "powershell -ExecutionPolicy Bypass -File .\\scripts\\package-worker.ps1",
    "build:desktop-assets": "npm run build:web && npm run build:worker",
    "verify:worker-packaged": "powershell -ExecutionPolicy Bypass -Command \"$env:VCS_WORKER_EXE=(Resolve-Path .\\src-tauri\\bin\\video-create-worker.exe).Path; .\\src-tauri\\bin\\video-create-worker.exe --health; python .\\tests\\smoke_v5_worker_protocol.py\"",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
