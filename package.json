{
  "name": "video-create-studio",
  "private": true,
  "version": "5.6.2",
  "type": "module",
  "scripts": {
    "build:web": "tsc && vite build",
    "dev": "vite --host 127.0.0.1 --port 1420",
    "build": "npm run build:web",
    "dev:desktop": "npm run tauri dev",
    "build:worker": "node ./scripts/package-worker.mjs",
    "build:desktop-assets": "npm run build:web && npm run build:worker",
    "check": "node ./scripts/check.mjs",
    "check:full": "node ./scripts/check.mjs --full",
    "clean:test-artifacts": "node ./scripts/clean-test-artifacts.mjs",
    "diagnostics:summary": "node ./scripts/error-code-summary.mjs",
    "verify:worker-packaged": "node ./scripts/verify-worker-packaged.mjs",
    "build:desktop": "node ./scripts/build-desktop.mjs",
    "build:desktop:msi": "npm run tauri -- build --bundles msi",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
